datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  MODEL
  AGENCY
  CLIENT
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(MODEL)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       Profile?
  model         Model?
  agency        Agency?
  client        Client?
  
  sentMessages     Message[]   @relation("SentMessages")
  receivedMessages  Message[]   @relation("ReceivedMessages")
  notifications     Notification[]
}

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                 String?
  avatarUrl           String?
  cloudinaryPublicId  String?
  location            String?
  phoneNumber         String?
  website             String?
  instagramUrl        String?
}

model Model {
  id                  String               @id @default(uuid())
  userId              String               @unique
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Model Attributes
  gender              String
  category            String               // Runway, Commercial, Editorial, Fitness, Beauty, Plus-size, Petite, Influencer
  height              Float                // in cm
  waist               Float?               // in cm
  hips                Float?               // in cm
  chest               Float?               // in cm
  shoeSize            Float?
  eyeColor            String?
  hairColor           String?
  experienceYears     Int                  @default(0)
  
  // Verification and Status
  isVerified          Boolean              @default(false)
  profileCompletion   Int                  @default(10) // Percentage (10 - 100)
  viewsCount          Int                  @default(0)
  
  // Agency relationship (optional, some models are freelance)
  agencyId            String?
  agency              Agency?              @relation(fields: [agencyId], references: [id])
  
  // Collections
  applications        CastingApplication[]
  bookings            Booking[]
  taggedEvents        Event[]              @relation("TaggedModels")
  reviews             Review[]
}

model Agency {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name                String
  logoUrl             String?
  cloudinaryPublicId  String?
  description         String?
  location            String
  isVerified          Boolean   @default(false)
  
  models              Model[]
  castings            Casting[]
}

model Client {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  company     String?
  website     String?
  bookings    Booking[]
  castings    Casting[]
}

model Casting {
  id                  String               @id @default(uuid())
  title               String
  description         String
  requirements        String
  location            String
  date                DateTime
  budget              Float
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  
  // Posted by either Client or Agency
  agencyId            String?
  agency              Agency?              @relation(fields: [agencyId], references: [id])
  clientId            String?
  client              Client?              @relation(fields: [clientId], references: [id])
  
  applications        CastingApplication[]
}

model CastingApplication {
  id          String            @id @default(uuid())
  castingId   String
  casting     Casting           @relation(fields: [castingId], references: [id], onDelete: Cascade)
  modelId     String
  model       Model             @relation(fields: [modelId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(PENDING)
  notes       String?
  appliedAt   DateTime          @default(now())
}

model Booking {
  id          String        @id @default(uuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  modelId     String
  model       Model         @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  date        DateTime
  duration    String
  budget      Float
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
}

model Event {
  id                  String       @id @default(uuid())
  name                String
  date                DateTime
  location            String
  description         String?
  createdAt           DateTime     @default(now())
  
  images              EventImage[]
  taggedModels        Model[]      @relation("TaggedModels")
}

model EventImage {
  id                  String   @id @default(uuid())
  eventId             String
  event               Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl            String
  cloudinaryPublicId  String
  uploadedAt          DateTime @default(now())
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  content     String
  isRead      Boolean  @default(false)
  sentAt      DateTime @default(now())
}

model MarketplaceService {
  id                  String   @id @default(uuid())
  title               String
  providerName        String
  providerRole        String   // Photographer, Makeup Artist, Runway Coach, Fashion Stylist, Studio Rental, Event Organizer
  description         String
  price               Float
  location            String
  imageUrl            String?
  cloudinaryPublicId  String?
  createdAt           DateTime @default(now())
}

model Review {
  id          String   @id @default(uuid())
  modelId     String
  model       Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  authorName  String
  rating      Int      @default(5)
  comment     String
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
